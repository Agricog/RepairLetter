# ============================================================
# RentShield — Environment Variables
# NEVER commit real values. Copy to .env.local for development.
# .env.local is in .gitignore — safe from commits.
# ============================================================

# Frontend (Vite — must be prefixed with VITE_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_API_URL=http://localhost:8787

# ============================================================
# Backend secrets — DO NOT put these in .env
# Set via: wrangler secret put SECRET_NAME
# ============================================================
# CLERK_SECRET_KEY
# DATABASE_URL
# DB_ENCRYPTION_KEY
# ANTHROPIC_API_KEY
# SPEECHMATICS_API_KEY
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET
# RESEND_API_KEY
# UPSTASH_REDIS_URL
# UPSTASH_REDIS_TOKEN
# CF_AI_TOKEN
# VAPID_PUBLIC_KEY
# VAPID_PRIVATE_KEY
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_APP_VERSION=0.1.0
